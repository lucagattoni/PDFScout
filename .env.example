ANTHROPIC_API_KEY=your-api-key-here

LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional — usage & caching knobs (see docs/03-reference/01-configuration.md)
# PDFSCOUT_LOG_USAGE=1        # per-API-call [USAGE] lines on stderr
# PDFSCOUT_CACHE_TTL=1h       # 1-hour prompt cache for multi-run workloads (default: 5m)
# PDFSCOUT_EFFORT=low         # output_config.effort on all calls (low|medium|high|xhigh|max); unset = model default
